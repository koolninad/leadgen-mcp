# Ollama / Gemma 4 Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Your Agency Name
SMTP_FROM_EMAIL=your-email@gmail.com

# Database
DB_PATH=./data/leadgen.db

# Tracking Server (for open/click tracking)
TRACKING_BASE_URL=http://localhost:8899

# Rate Limits
MAX_SCAN_CONCURRENCY=10
MAX_PLATFORM_CONCURRENCY=5
EMAIL_RATE_PER_MINUTE=2
EMAIL_RATE_PER_HOUR=30

# Optional: Proxy for platform crawling
# HTTP_PROXY=http://user:pass@proxy:port

# Proxy Rotation (one proxy per line, supports http:// socks5://)
# PROXY_LIST_FILE=./data/proxies.txt

# IPv6 Rotation (requires IPv6 subnet assigned to your server)
IPV6_ENABLED=false
IPV6_PREFIX=
IPV6_POOL_SIZE=100

# LinkedIn Stealth Browser (use a burner account!)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_SESSION_FILE=./data/linkedin_session.json
LINKEDIN_HEADLESS=true
LINKEDIN_SLOW_MO=500

# Agency Details (used in email templates)
AGENCY_NAME=Your Agency Name
AGENCY_WEBSITE=https://your-agency.com
AGENCY_PHONE=+1-555-0100
AGENCY_ADDRESS=123 Tech Street, San Francisco, CA 94105
